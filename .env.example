GROQ_API_KEY=
LLM_PROVIDER=
GROQ_BASE_URL=

# Verify these IDs against Groq's live model list before relying on them.
ANALYSIS_MODEL=
FILTER_MODEL=

MAX_PAGES=
CHAR_BUDGET=
PER_PAGE_CHAR_CAP=

REQUEST_TIMEOUT=
MAX_CONCURRENT_LEADS=

# Set to "false" on memory-constrained hosts (e.g. Render's 512MB free tier) -
# even one headless Chromium instance can exceed 512MB. Sites that need JS
# rendering then fall back to a search-snippet brief instead of crashing.
ENABLE_JS_RENDERING=

# Free key from https://tavily.com (1000 searches/month, no card required).
# Without it, name->URL search falls back to Brave (if BRAVE_API_KEY is set)
# or scraping DuckDuckGo, which gets bot-blocked from datacenter IPs.
TAVILY_API_KEY=
BRAVE_API_KEY=

DB_PATH=
CACHE_PATH=

CORS_ORIGINS=
